{
  "manifest_version": 3,
  "name": "Ask Gemini",
  "version": "1.0",
  "description": "Ask Gemini directly from your browser's omnibox.",
  "omnibox": {
    "keyword": "gemini"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://gemini.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/app*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
